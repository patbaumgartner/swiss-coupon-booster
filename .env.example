# ─────────────────────────────────────────────────────────────────────────────
# Swiss Coupon Booster – environment configuration template
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit .env to source control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Migros (Cumulus) credentials ─────────────────────────────────────────────
MIGROS_USER_EMAIL=your-migros-email@example.com
MIGROS_USER_PASSWORD=your-migros-password

# ── Coop (Supercard) credentials ─────────────────────────────────────────────
COOP_USER_EMAIL=your-coop-email@example.com
COOP_USER_PASSWORD=your-coop-password

# ── Auth modes ────────────────────────────────────────────────────────────────
# 'browser' (default) — uses Java Playwright directly.
#   No sidecar needed. Suitable for local development with `mvn spring-boot:run`.
#   May be challenged or blocked by DataDome on non-residential IPs.
# 'sidecar'           — delegates login to the stealth-service container.
#   Bypasses DataDome via Patchright + Xvfb virtual display.
#   Set automatically by docker-compose.yml and docker-compose.build.yml.
#   Also used with `mvn spring-boot:run` when auth mode is sidecar
#   (Spring Boot starts docker-compose.sidecar.yml automatically).
#   Use this when running via Docker on a home server or NAS.
MIGROS_AUTH_MODE=browser
COOP_AUTH_MODE=browser

# ── Feature toggles ───────────────────────────────────────────────────────────
MIGROS_LOGIN_ENABLED=true
COOP_LOGIN_ENABLED=true
MIGROS_STARTUP_RUN_ENABLED=true
COOP_STARTUP_RUN_ENABLED=true

# ── Optional: long-running Spring server profile with built-in scheduler ─────
# Enable server mode (Spring MVC app + daily schedulers) instead of one-shot runner.
# SPRING_PROFILES_ACTIVE=server
# COUPONBOOSTER_SCHEDULER_ZONE=Europe/Zurich
# COOP_STARTUP_RUN_ENABLED=false
# MIGROS_STARTUP_RUN_ENABLED=false
# COOP_SCHEDULER_ENABLED=true
# MIGROS_SCHEDULER_ENABLED=true
# COOP_SCHEDULER_CRON=0 0 6 * * *
# MIGROS_SCHEDULER_CRON=0 10 6 * * *

# ── Docker image version (optional) ──────────────────────────────────────────
# Leave empty or 'latest' for the most recent stable release.
# Set to a specific version (e.g. 1.2.0) to pin both images.
# VERSION=latest

# ── Stealth sidecar tuning (optional) ─────────────────────────────────────────
# HEADLESS is always false inside the container (Xvfb virtual display).
# chromium-headless-shell is detected by DataDome; full Chromium + Xvfb is not.
# STEALTH_SLOW_MO_MS=500
# STEALTH_TIMEOUT_MS=25000
# STEALTH_TYPING_DELAY_MS=80
# STEALTH_LOG_LEVEL=info

# ── Optional: residential proxy ───────────────────────────────────────────────
# Not needed when running on a home network / NAS (Swiss residential IP).
# Cloud / datacenter IPs are pre-flagged by DataDome and will trigger challenges.
# Format: http://user:pass@host:port  or  socks5://user:pass@host:port
# PROXY_URL=

# ── JVM tuning (optional) ─────────────────────────────────────────────────────
# JAVA_OPTS=-XX:+UseZGC -Xmx512m
