##############################################################################
# Swiss Coupon Booster – .gitattributes
# Normalises line endings so Java (LF) and Windows scripts (CRLF) are handled
# correctly across platforms.
##############################################################################

# ── Default: normalise all text files to LF ──────────────────────────────────
* text=auto eol=lf

# ── Java ─────────────────────────────────────────────────────────────────────
*.java        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.properties  text eol=lf
*.json        text eol=lf

# ── Python ───────────────────────────────────────────────────────────────────
*.py          text eol=lf
*.toml        text eol=lf
*.ini         text eol=lf
*.cfg         text eol=lf
*.txt         text eol=lf
*.sh          text eol=lf

# ── Docker ───────────────────────────────────────────────────────────────────
Dockerfile    text eol=lf
*.dockerfile  text eol=lf

# ── Maven wrapper ─────────────────────────────────────────────────────────────
# mvnw must use LF even on Windows, mvnw.cmd must use CRLF
coupon-booster/mvnw     text eol=lf
coupon-booster/mvnw.cmd text eol=crlf

# ── Documentation ─────────────────────────────────────────────────────────────
*.md          text eol=lf

# ── Binary files — no line-ending conversion ─────────────────────────────────
*.jar         binary
*.png         binary
*.jpg         binary
*.gif         binary
*.ico         binary
*.zip         binary
*.tar.gz      binary
